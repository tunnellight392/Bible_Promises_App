<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sky_top"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:text="@string/accessibility"
            android:textColor="@color/text_on_image"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:alpha="0.8"
            android:text="@string/accessibility_subtitle"
            android:textColor="@color/text_on_image_dim"
            android:textSize="13sp" />

        <!-- Live preview -->
        <TextView
            android:id="@+id/previewText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="#1AFFFFFF"
            android:gravity="center"
            android:lineSpacingMultiplier="1.25"
            android:minHeight="140dp"
            android:padding="20dp"
            android:text="@string/accessibility_preview_text"
            android:textColor="@color/text_on_image"
            android:textStyle="italic" />

        <!-- Font size -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/font_size"
            android:textColor="@color/text_on_image"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/sizeValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="serif"
            android:textColor="@color/accent_gold"
            android:textSize="14sp"
            android:textStyle="bold" />

        <SeekBar
            android:id="@+id/sizeSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:max="3" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:background="#26FFFFFF" />

        <!-- Font style -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/font_style"
            android:textColor="@color/text_on_image"
            android:textSize="16sp" />

        <RadioGroup
            android:id="@+id/fontStyleGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/fontSerif"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:paddingStart="8dp"
                android:paddingVertical="8dp"
                android:text="@string/font_serif"
                android:textColor="@color/text_on_image"
                android:textSize="18sp" />

            <RadioButton
                android:id="@+id/fontSansSerif"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:paddingStart="8dp"
                android:paddingVertical="8dp"
                android:text="@string/font_sans_serif"
                android:textColor="@color/text_on_image"
                android:textSize="18sp" />

            <RadioButton
                android:id="@+id/fontMonospace"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:paddingStart="8dp"
                android:paddingVertical="8dp"
                android:text="@string/font_monospace"
                android:textColor="@color/text_on_image"
                android:textSize="18sp" />
        </RadioGroup>
    </LinearLayout>
</ScrollView>
