<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sky_top"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:text="@string/feedback"
            android:textColor="@color/text_on_image"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:alpha="0.8"
            android:text="@string/feedback_subtitle"
            android:textColor="@color/text_on_image_dim"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/feedbackInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="#1AFFFFFF"
            android:gravity="top|start"
            android:hint="@string/feedback_hint"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="6"
            android:padding="16dp"
            android:textColor="@color/text_on_image"
            android:textColorHint="@color/text_on_image_dim"
            android:textSize="16sp"
            android:autofillHints="" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/sendFeedbackButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/feedback_send"
            android:textSize="16sp" />
    </LinearLayout>
</ScrollView>
