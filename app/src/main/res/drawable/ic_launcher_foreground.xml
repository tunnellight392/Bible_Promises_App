<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive-icon foreground: the sun rising in a mountain pass.
     Content is kept within the central safe zone of the 108x108 canvas.
     Draw order: glow -> distant range -> sun -> near range. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Warm glow in the sky around the sun -->
    <path android:pathData="M26,50 a28,28 0 1,0 56,0 a28,28 0 1,0 -56,0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="50"
                android:gradientRadius="28">
                <item android:offset="0" android:color="#80FFD79A" />
                <item android:offset="0.6" android:color="#40FFC97A" />
                <item android:offset="1" android:color="#00FFC97A" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Distant mountain range (behind the sun) -->
    <path
        android:fillColor="#4C7B5C"
        android:pathData="M-4,108 L-4,84 L18,62 L36,76 L54,60 L72,76 L90,60 L112,84 L112,108 Z" />

    <!-- The sun -->
    <path android:pathData="M39,50 a15,15 0 1,0 30,0 a15,15 0 1,0 -30,0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="48"
                android:gradientRadius="16">
                <item android:offset="0" android:color="#FFFDF1CF" />
                <item android:offset="1" android:color="#FFF8C25A" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Near mountain range (in front, framing the sun) -->
    <path
        android:fillColor="#1E3A2A"
        android:pathData="M-4,108 L-4,92 L26,50 L42,70 L54,60 L66,70 L82,48 L112,92 L112,108 Z" />
</vector>
