<?xml version="1.0" encoding="utf-8"?>
<!-- Scrim for topic tiles: image shows through at the top, darkening toward the
     bottom so the topic name stays legible. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="270"
        android:startColor="#22000000"
        android:centerColor="#59000000"
        android:endColor="#CC000000" />
</shape>
